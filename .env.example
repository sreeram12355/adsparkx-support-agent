# Copy this file to ".env" and fill in your values.
# The .env file is git-ignored and must NEVER be committed.

# --- Required: Google Gemini API key for response generation & persona detection ---
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# --- Optional overrides (sensible defaults are used if omitted) ---

# Chat model used for persona detection and answer generation
GEMINI_MODEL=gemini-2.5-flash

# Local embedding model (Sentence-Transformers) — runs offline, no API cost
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval settings
TOP_K=4
# Minimum cosine similarity (0-1) for a chunk to count as "relevant".
# If the best chunk is below this, the agent escalates (low-confidence).
MIN_RETRIEVAL_SCORE=0.30

# Number of unresolved/dissatisfied turns before escalating to a human
MAX_DISSATISFACTION_TURNS=2
